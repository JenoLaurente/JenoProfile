# Node contact mail server
CONTACT_SERVER_PORT=3001
RATE_LIMIT_MS=60000
RATE_LIMIT_ENABLED=false

# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_account@example.com
SMTP_PASS=your_smtp_password_or_app_password

# Email addresses
MAIL_FROM=your_smtp_account@example.com
MAIL_TO=jenoaldrei.official@gmail.com

# Send confirmation email to sender
AUTO_REPLY_ENABLED=true

# Try to use client email as notification "From" header (falls back if provider rejects)
NOTIFICATION_FROM_CLIENT=true

# Frontend endpoint override (optional)
VITE_CONTACT_API_URL=/api/contact
